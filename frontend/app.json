{
  "expo": {
    "name": "DengueGuard",
    "description": "DengueGuard is a mobile application for early detection of dengue fever using artificial intelligence.",
    "slug": "dengue-kbs",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./src/assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": ["**/*"],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/android-icon-foreground.png",
        "backgroundColor": "#0F172A"
      },
      "package": "com.dengue.kbs",
      "softwareKeyboardLayoutMode": "resize",
      "navigationBar": {
        "barStyle": "light-content",
        "backgroundColor": "#0F172A"
      }
    },
    "web": {
      "favicon": "./src/assets/favicon.png"
    },
    "plugins": ["expo-asset", "expo-secure-store"],
    "extra": {
      "eas": {
        "projectId": "ed147549-7430-4fdb-aadf-583cc084eb32"
      }
    }
  }
}
